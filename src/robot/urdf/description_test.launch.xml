<?xml version="1.0"?>
<launch>
    <let name="urdf_file" value="$(find-pkg-share robot)/urdf/description_test.urdf" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description" value="$(command 'cat $(var urdf_file)')"/>
    </node>

    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" name="joint_state_publisher_gui" output="screen" />

    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" args="-d $(find-pkg-share robot)/config/description_test.rviz" />
</launch>