<?xml version="1.0"?>
<robot name="rrr_robot_arm_with_gripper">

    <!-- ✅ world link แก้ KDL warning -->
    <link name="world"/>

    <joint name="world_to_base" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <cylinder length="0.2" radius="0.3"/>
            </geometry>
            <material name="blue">
                <color rgba="0.0 0.0 0.8 1.0"/>
            </material>
        </visual>
        <!-- ✅ collision -->
        <collision>
            <geometry>
                <cylinder length="0.2" radius="0.3"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.129" ixy="0.0" ixz="0.0" iyy="0.129" iyz="0.0" izz="0.225"/>
        </inertial>
    </link>

    <link name="rod1_link">
        <visual>
            <origin xyz="0 0 0.3" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.6" radius="0.1"/>
            </geometry>
            <material name="grey">
                <color rgba="0.5 0.5 0.5 1.0"/>
            </material>
        </visual>
        <!-- ✅ collision -->
        <collision>
            <origin xyz="0 0 0.3" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.6" radius="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.3" rpy="0 0 0"/>
            <mass value="1.2"/>
            <inertia ixx="0.039" ixy="0.0" ixz="0.0" iyy="0.039" iyz="0.0" izz="0.006"/>
        </inertial>
    </link>

    <link name="rod2-link">
        <visual>
            <origin xyz="0 0 0.3" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.6" radius="0.08"/>
            </geometry>
            <material name="white">
                <color rgba="1.0 1.0 1.0 1.0"/>
            </material>
        </visual>
        <!-- ✅ collision -->
        <collision>
            <origin xyz="0 0 0.3" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.6" radius="0.08"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.3" rpy="0 0 0"/>
            <mass value="1.2"/>
            <inertia ixx="0.0379" ixy="0.0" ixz="0.0" iyy="0.0379" iyz="0.0" izz="0.00384"/>
        </inertial>
    </link>

    <link name="rod3-link">
        <visual>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.4" radius="0.06"/>
            </geometry>
            <material name="red">
                <color rgba="0.8 0.0 0.0 1.0"/>
            </material>
        </visual>
        <!-- ✅ collision -->
        <collision>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.4" radius="0.06"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <mass value="0.8"/>
            <inertia ixx="0.0113" ixy="0.0" ixz="0.0" iyy="0.0113" iyz="0.0" izz="0.00144"/>
        </inertial>
    </link>

    <link name="left_finger">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.03 0.1"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
        <!-- ✅ collision -->
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.03 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0000908" ixy="0.0" ixz="0.0" iyy="0.0000867" iyz="0.0" izz="0.0000108"/>
        </inertial>
    </link>

    <link name="right_finger">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.03 0.1"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0"/>
            </material>
        </visual>
        <!-- ✅ collision -->
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.03 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx="0.0000908" ixy="0.0" ixz="0.0" iyy="0.0000867" iyz="0.0" izz="0.0000108"/>
        </inertial>
    </link>

    <joint name="base_to_rod1" type="revolute">
        <parent link="base_link"/>
        <child link="rod1_link"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="rod1_to_rod2" type="revolute">
        <parent link="rod1_link"/>
        <child link="rod2-link"/>
        <origin xyz="0 0 0.6" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="rod2_to_rod3" type="revolute">
        <parent link="rod2-link"/>
        <child link="rod3-link"/>
        <origin xyz="0 0 0.6" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.0" upper="2.0" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="rod3_to_left_finger" type="prismatic">
        <parent link="rod3-link"/>
        <child link="left_finger"/>
        <origin xyz="0 -0.04 0.4" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.04" upper="0.0" effort="10.0" velocity="1.0"/>
    </joint>

    <joint name="rod3_to_right_finger" type="prismatic">
        <parent link="rod3-link"/>
        <child link="right_finger"/>
        <origin xyz="0 0.04 0.4" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="0.0" upper="0.04" effort="10.0" velocity="1.0"/>
    </joint>

    <!-- ✅ อัปเดต plugin เป็นเวอร์ชันใหม่ gz_ros2_control -->
    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find motion_robot_moveit_config)/config/ros2_controllers.yaml</parameters>
            <controller_manager_name>controller_manager</controller_manager_name>
        </plugin>
    </gazebo>

</robot>